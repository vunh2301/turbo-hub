{
  "name": "turbo-hub",
  "version": "0.1.0",
  "description": "AI Agent Hub — Multi-agent collaboration platform. Any AI client with MCP can join.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "turbo-hub": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "mcp": "tsx mcp/index.ts",
    "build:mcp": "tsup mcp/index.ts --format esm --outDir dist/mcp"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fastify": "^5.2.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "ai",
    "agent",
    "hub",
    "mcp",
    "multi-agent",
    "collaboration"
  ],
  "license": "MIT"
}
